# Benchmark configuration. Sourced by all scripts.
# Change these to retune the run; every run records the model it used in meta.json.

# Session model held constant across ALL runs (the fair-comparison anchor).
# Default matches how the operator actually runs decaf (Opus-class session).
# Note: some tools hard-pin their own models regardless of this (see tools.json model_policy).
BENCH_MODEL="claude-opus-4-8"

# Claude Code CLI binary used to launch each isolated per-cell session.
CLAUDE_BIN="claude"

# Permission posture for the isolated per-cell `claude -p` sessions. EMPTY BY DEFAULT
# (normal permission behavior). Unattended runs need SOME posture because each cell
# autonomously runs gh/bash/subagents to review a PR. YOU must opt in explicitly, choosing
# how much to trust it. Safer -> riskier:
#   --permission-mode acceptEdits      # auto-accept edits, still gates other actions
#   --allowedTools "Bash(gh:*) Bash(git:*) Read Grep Glob Task"   # an explicit allowlist
#   --dangerously-skip-permissions     # no gate at all (reviews are read-only/no-post, but still: your call)
# Leave empty to run cells only where you can answer prompts, or set one of the above.
# Operator-approved (2026-07-16): full bypass. Reviews are read-only / no-post, run against
# public OSS PRs in throwaway shallow checkouts under repos/.
PERM_FLAGS="--dangerously-skip-permissions"

# Repeats per (tool x subject) cell.
REPEATS=2
